# ─── FinGuard AI Backend Configuration ───────────────
CEREBRAS_API_KEY=your-cerebras-api-key-here
CEREBRAS_MODEL=gpt-oss-120b
CHROMA_PERSIST_DIR=/app/data/chromadb
UPLOAD_DIR=/app/data/uploads
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://127.0.0.1:3000,http://127.0.0.1:3002,https://your-vercel-app.vercel.app
API_JWT_SECRET=replace-with-a-random-32-plus-character-secret
API_JWT_ISSUER=finguard-web
API_JWT_AUDIENCE=finguard-backend
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_BACKEND=onnx-int8
EMBEDDING_QUANTIZATION=avx2
EMBEDDING_CACHE_DIR=/app/data/embeddings
EMBEDDING_TRUST_REMOTE_CODE=false
EMBEDDING_NORMALIZE=true
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSION=768
GEMINI_EMBEDDING_BATCH_SIZE=32
GEMINI_EMBEDDING_TIMEOUT_SECONDS=60
PDF_TEXT_EXTRACTOR=auto
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RERANKER_BACKEND=onnx-int8
RERANKER_QUANTIZATION=avx2
RERANKER_MAX_LENGTH=384
RERANKER_CACHE_DIR=/app/data/rerankers
RERANKER_TRUST_REMOTE_CODE=false
MODEL_WARMUP_ENABLED=true
RAG_TOP_K=15
RAG_RERANK_TOP_N=3
MAX_UPLOAD_BYTES=25000000
